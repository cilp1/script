-- Auto Headlock Toggle (very frequent spam of DamageTool)
local autoHeadlock = false
Tab:CreateToggle({
   Name = "Auto Headlock (Very Frequent)",
   CurrentValue = false,
   Flag = "AutoHeadlock",
   Callback = function(Value)
      autoHeadlock = Value
      if Value then
         spawn(function()
            while autoHeadlock do
               local success, err = pcall(function()
                  local args = {"DamageTool"}
                  game:GetService("ReplicatedStorage")
                     :WaitForChild("events", 5)
                     :WaitForChild("MainKeys", 5)
                     :FireServer(unpack(args))
               end)
               if not success then
                  warn("[Auto Headlock] Error: " .. tostring(err))
               end
               task.wait(0.018)  -- Very frequent (~40x per second) — lower to 0.015 if you want even faster, but test for detection/kicks
            end
         end)
      end
   end,
})

