local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local Window = Rayfield:CreateWindow({
   Name = "Private script",
   LoadingTitle = "loading",
   LoadingSubtitle = "made by kd",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = nil,
      FileName = "SquabbleConfig"
   },
   KeySystem = false
})

local Tab = Window:CreateTab("Main Features")

-- Infinite Health Button: true → false → true)
local Button = Tab:CreateButton({
   Name = "Infinite Health",
   Callback = function()
      local ReplicatedStorage = game:GetService("ReplicatedStorage")
      local events = ReplicatedStorage:FindFirstChild("events")
      if not events then
         Rayfield:Notify({Title = "Error", Content = "events folder not found!", Duration = 5})
         return
      end
      
      local PvpToggle = events:FindFirstChild("PvpToggle")
      if not PvpToggle then
         Rayfield:Notify({Title = "Error", Content = "PvpToggle remote not found!", Duration = 5})
         return
      end
      
      local function fire(state)
         pcall(function()
            PvpToggle:FireServer(state)
         end)
      end
      
      fire(true)
      task.wait(0.005)
      fire(false)
      task.wait(0.005)
      fire(true)
      
      Rayfield:Notify({
         Title = "Infinite Health Triggered",
         Content = "Super-fast PvP sequence fired!\nTest if glitched/invincible.",
         Duration = 5,
      })
   end,
})

